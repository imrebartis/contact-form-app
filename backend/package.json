{
  "name": "contact-form-backend",
  "version": "1.0.0",
  "description": "Backend for contact form application",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "prebuild": "rimraf dist && echo Starting build process...",
    "build": "pnpm run format && pnpm run test:run && pnpm run lint && pnpm run ts-check && node ./node_modules/webpack/bin/webpack.js --config webpack.config.js --mode=production",
    "build:vercel": "pnpm run format && pnpm run lint && pnpm run ts-check && node ./node_modules/webpack/bin/webpack.js --config webpack.config.js --mode=production",
    "build:esm": "node ./node_modules/webpack/bin/webpack.js --config webpack.config.js --mode=production",
    "dev": "cross-env tsx src/index.ts",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "preview": "node --experimental-specifier-resolution=node dist/index.js",
    "check-build": "node -e \"const fs=require('fs'); const path=require('path'); const exists=fs.existsSync('./dist'); console.log('dist directory exists:', exists); if(exists) { const files=fs.readdirSync('./dist'); console.log('Files in dist:', files); }\"",
    "ts-check": "tsc --noEmit",
    "install-deps": "pnpm add -D webpack webpack-cli webpack-node-externals ts-loader rimraf tsconfig-paths-webpack-plugin",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check \"./**/*.{js,ts}\"",
    "lint:fix": "eslint . --fix && prettier --write \"./**/*.{js,ts}\"",
    "format": "prettier --write \"./**/*.{js,ts}\"",
    "migration:down": "cross-env tsx src/util/rollback-migrations.ts",
    "migration:up": "cross-env tsx src/util/run-migrations.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-validator": "^3.0.2",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.11.11",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "1.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^8.10.0",
    "lint-staged": "^15.5.0",
    "nodemon": "^3.0.1",
    "prettier": "2.8.8",
    "rimraf": "^5.0.10",
    "shx": "^0.3.4",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "5.3.3",
    "vitest": "^1.2.1",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "pg": "^8.14.1",
    "sequelize": "^6.37.6",
    "uuid": "^11.1.0"
  }
}